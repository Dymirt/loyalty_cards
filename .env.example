# Django development defaults. Replace every secret in production.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_TRUST_X_FORWARDED_PROTO=False
LOYALTY_ALLOWED_HOSTS_FILE=
# Deprecated one-release fallback: TURNKEY_ALLOWED_HOSTS_FILE=
LOCAL_WEB_PORT=8000
DJANGO_TIME_ZONE=Europe/Warsaw
APP_BASE_URL=http://localhost:8000
MEDIA_ROOT=media
ENROLLMENT_LINK_TTL_DAYS=30
MARKETING_LEGAL_NAME=MB Studio
MARKETING_LEGAL_ADDRESS=
MARKETING_CONTACT_EMAIL=kontakt@mbstudio.online
MARKETING_PRIVACY_VERSION=2026-07-18
MARKETING_TERMS_VERSION=2026-07-18
MARKETING_LEAD_RETENTION_DAYS=365
LEGACY_DEFAULT_TENANT_SLUG=marta-banaszek-atelier-cafe
# Protected production ZIPs. Keep this outside MEDIA_ROOT and any web-server alias.
PRINT_PACKAGE_ROOT=var/print-packages
BACKUP_ROOT=local-data/backups
# Comma-separated Fernet keys. The first encrypts new values; the rest decrypt old values.
# This is platform configuration and must be set before rotating DJANGO_SECRET_KEY.
TENANT_SECRETS_ENCRYPTION_KEYS=

# Local development uses SQLite. For TurnKey/MariaDB use the commented values.
DB_ENGINE=django.db.backends.sqlite3
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=django
# DB_USER=django
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=3306

# Email. The console backend prints messages locally without sending them.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=loyalty@example.com

# Platform-owned Client Application credentials issued by Dotykačka. These are
# used only to open Connector v2. Its returned Refresh Token and Cloud ID belong
# to the authorized tenant and are stored in the database.
# The legacy values below are read only by the first production migration and
# must remain present until that migration has safely imported them.
DOTYKACKA_AUTHORIZATION_TOKEN=
DOTYKACKA_CLOUD_ID=0
DOTYKACKA_DISCOUNT_GROUP_ID=0
DOTYKACKA_CONNECTOR_CLIENT_ID=
DOTYKACKA_CONNECTOR_CLIENT_SECRET=
DOTYKACKA_CONNECTOR_URL=https://admin.dotykacka.cz/client/connect/v2
DOTYKACKA_API_BASE_URL=https://api.dotykacka.cz
DOTYKACKA_HTTP_TIMEOUT=15
DOTYKACKA_TOKEN_EXPIRY_SKEW=120
DOTYKACKA_MAX_PAGES=1000

# Brevo API keys/list IDs are tenant-owned database settings. BREVO_API_KEY and
# BREVO_LIST_ID are also read by the first legacy-tenant migration.
BREVO_API_KEY=
BREVO_LIST_ID=25
BREVO_API_BASE_URL=https://api.brevo.com/v3
BREVO_HTTP_TIMEOUT=15
INTEGRATION_HTTP_RETRIES=2
DEFAULT_PHONE_COUNTRY_CODE=+48

# Google Wallet platform signing/service-account configuration. All tenants use the
# same central issuer; each class suffix is derived from the tenant's unique card prefix.
GOOGLE_WALLET_SERVICE_ACCOUNT_FILE=secrets/google-wallet-service-account.json
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_ISSUER_ID=3388000000022973962
GOOGLE_WALLET_ORIGINS=http://localhost:8000
GOOGLE_WALLET_API_BASE_URL=https://walletobjects.googleapis.com/walletobjects/v1
GOOGLE_WALLET_HTTP_TIMEOUT=15
GOOGLE_WALLET_REMOTE_SYNC_ENABLED=True

# Apple Wallet identifiers. Signing files are provisioned outside Git.
APPLE_WALLET_PASS_TYPE_IDENTIFIER=
APPLE_WALLET_TEAM_IDENTIFIER=
APPLE_WALLET_TEMPLATE_DIR=media/mypass_template

# Production proxy/cookie options
DJANGO_TRUST_X_FORWARDED_PROTO=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Request/upload and database-backed abuse controls.
DATA_UPLOAD_MAX_MEMORY_SIZE=67108864
FILE_UPLOAD_MAX_MEMORY_SIZE=2621440
DATA_UPLOAD_MAX_NUMBER_FIELDS=200
DATA_UPLOAD_MAX_NUMBER_FILES=4
MARKETING_CONTACT_RATE_LIMIT=5
ENROLLMENT_RATE_LIMIT=10
DOTYKACKA_CONNECT_RATE_LIMIT=10
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=3600
CONNECT_RATE_LIMIT_WINDOW_SECONDS=900
# Set only to the exact reverse-proxy networks that sanitize/append
# X-Forwarded-For. Leave empty when Apache receives client traffic directly.
LOYALTY_TRUSTED_PROXY_CIDRS=

# Database-backed worker health and platform monitoring.
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_MAX_AGE_SECONDS=90
OPERATIONS_MONITOR_INTERVAL_SECONDS=60
MONITOR_LOW_INVENTORY_THRESHOLD=50
MONITOR_ENTITLEMENT_WARNING_PERCENT=80
MONITOR_PROVIDER_AUTH_FAILURE_THRESHOLD=3
LOYALTY_LOG_LEVEL=INFO
